local TIER_TOKEN_PAYOUTS = {
    [1] = 1,  -- Tier 1 = 1 Token
    [2] = 4,  -- Tier 2 = 4 Tokens
    [3] = 10, -- Tier 3 = 10 Tokens
    [4] = 25, -- Tier 4 = 25 Tokens
    [5] = 50  -- Tier 5 = 50 Tokens
}

local function getTokenValue(rootObj, mainPart)
    local val = 1
    local detectedSource = "Tier 1 (1 Token)"

    pcall(function()
        -- 1. Scan FullPath, Root Object Name, AND Parent Name for Tier matching
        local searchTargets = {
            rootObj.Name,
            rootObj:GetFullName(),
            (rootObj.Parent and rootObj.Parent.Name or "")
        }

        -- Also add any descendant names if rootObj is a Model
        if rootObj:IsA("Model") then
            for _, child in ipairs(rootObj:GetChildren()) do
                table.insert(searchTargets, child.Name)
            end
        end

        for _, str in ipairs(searchTargets) do
            local tNum = str:match("[Tt]ier%s*(%d+)") or str:match("[Tt]ier_(%d+)") or str:match("[Tt]ier(%d+)")
            if tNum then
                local num = tonumber(tNum)
                if num and TIER_TOKEN_PAYOUTS[num] then
                    val = TIER_TOKEN_PAYOUTS[num]
                    detectedSource = string.format("Sun: Tier %d (%d Tokens)", num, val)
                    return
                elseif num and num > 0 then
                    val = num
                    detectedSource = string.format("Tier Match %d", num)
                    return
                end
            end
        end

        -- 2. Check IntValue / NumberValue Children / Descendants
        for _, child in ipairs(rootObj:GetDescendants()) do
            if (child:IsA("IntValue") or child:IsA("NumberValue")) and child.Value > 0 then
                local nameLower = string.lower(child.Name)
                if nameLower:find("val") or nameLower:find("amt") or nameLower:find("token") or nameLower:find("reward") or nameLower:find("tier") or nameLower:find("cash") then
                    val = child.Value
                    detectedSource = string.format("Value '%s' = %d", child.Name, child.Value)
                    return
                end
            end
        end

        -- 3. Check Attributes on Root or MainPart
        local attrs = rootObj:GetAttributes()
        for k, v in pairs(attrs) do
            if typeof(v) == "number" and v > 0 then
                local kLower = string.lower(k)
                if kLower:find("val") or kLower:find("amt") or kLower:find("tier") or kLower:find("token") or kLower:find("reward") then
                    val = v
                    detectedSource = string.format("Attribute '%s' = %d", k, v)
                    return
                end
            end
        end
    end)
    return val, detectedSource
end

local function getTokens()
    local tokens = {}
    local processedModels = {}
    local totalValue = 0

    pcall(function()
        local effects = Workspace:FindFirstChild("Effects")
        local ticketsFolder = effects and (effects:FindFirstChild("Tickets") or effects:FindFirstChild("Collectables") or effects:FindFirstChild("Tokens"))
        
        -- 1. Direct Scan of Workspace.Effects.Tickets (or Collectables/Tokens)
        if ticketsFolder then
            for _, v in ipairs(ticketsFolder:GetChildren()) do
                if (v:IsA("Model") or v:IsA("BasePart")) and not processedModels[v] then
                    local fullPathLower = string.lower(v:GetFullName())
                    local isBuffItem = fullPathLower:find("coconut") 
                        or fullPathLower:find("frutiger") 
                        or fullPathLower:find("speed") 
                        or fullPathLower:find("jump") 
                        or fullPathLower:find("drink") 
                        or fullPathLower:find("soda") 
                        or fullPathLower:find("buff") 
                        or fullPathLower:find("cola")
                    
                    if not isBuffItem then
                        processedModels[v] = true
                        local mainPart = v:IsA("BasePart") and v or (v:FindFirstChild("HumanoidRootPart") or v:FindFirstChild("Mover") or v:FindFirstChildWhichIsA("BasePart", true))
                        if mainPart and mainPart.Parent then
                            local itemVal, sourceStr = getTokenValue(v, mainPart)
                            totalValue = totalValue + itemVal
                            table.insert(tokens, { Part = mainPart, Value = itemVal, Model = v, Source = sourceStr })
                        end
                    end
                end
            end
        end

        -- 2. Fallback Workspace Root Scan for Ticket / Token / Tier / Sun models
        for _, v in ipairs(Workspace:GetChildren()) do
            if (v:IsA("Model") or v:IsA("BasePart")) and not processedModels[v] and v.Name ~= "Effects" then
                local fullPathLower = string.lower(v:GetFullName())
                local isTicket = fullPathLower:find("ticket") 
                    or fullPathLower:find("tier") 
                    or fullPathLower:find("token") 
                    or fullPathLower:find("sun") 
                    or fullPathLower:find("event")
                
                local isBuffItem = fullPathLower:find("coconut") 
                    or fullPathLower:find("frutiger") 
                    or fullPathLower:find("speed") 
                    or fullPathLower:find("jump") 
                    or fullPathLower:find("buff") 
                    or fullPathLower:find("drink") 
                    or fullPathLower:find("soda") 
                    or fullPathLower:find("cola")

                if isTicket and not isBuffItem then
                    processedModels[v] = true
                    local mainPart = v:IsA("BasePart") and v or (v:FindFirstChild("HumanoidRootPart") or v:FindFirstChild("Mover") or v:FindFirstChildWhichIsA("BasePart", true))
                    if mainPart and mainPart.Parent then
                        local itemVal, sourceStr = getTokenValue(v, mainPart)
                        totalValue = totalValue + itemVal
                        table.insert(tokens, { Part = mainPart, Value = itemVal, Model = v, Source = sourceStr })
                    end
                end
            end
        end
    end)
    return tokens, totalValue
end

