-- Responsive Auto-Scale for Cloudphone & Small Roblox Windows
local isUserResized = false

local function updateResponsiveScale()
    if isUserResized then return end
    local cam = Workspace.CurrentCamera
    if not cam then return end
    local vp = cam.ViewportSize
    -- On small windows / Cloudphone (e.g. Viewport width 360px - 600px), automatically scale UI down nicely
    local targetScale = math.clamp(vp.X / 960, 0.65, 1.25)
    uiScale.Scale = math.floor(targetScale * 20 + 0.5) / 20
end

task.spawn(function()
    task.wait(0.1)
    updateResponsiveScale()
    if Workspace.CurrentCamera then
        Workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(updateResponsiveScale)
    end
end)

