local function runFarm()
    if not safePos then
        local plt = createSkyPlatform()
        safePos = CFrame.new(plt.Position + Vector3.new(0, 4, 0))
        safeLbl.Text = string.format("Safe Pos: Custom (%.1f, %.1f, %.1f)", plt.Position.X, plt.Position.Y + 4, plt.Position.Z)
        safeLbl.TextColor3 = Color3.fromRGB(100, 255, 140)
    end

    while farmRunning do
        local hrp = getHRP()
        if hrp then
            if (hrp.Position - safePos.Position).Magnitude > 20 then
                hrp.CFrame = safePos
            end

            local initialTokens, initialVal = getTokens()

            if #initialTokens > 0 then
                for i = WAIT_COLLECT, 1, -1 do
                    if not farmRunning then break end
                    local currentTokens, totalValue = getTokens()
                    local count = #currentTokens
                    
                    setStatus(string.format("Accumulating: %d Tickets", totalValue), Color3.fromRGB(255, 229, 190))
                    waitLbl.Text = string.format("Collecting in: %ds (%d items)", i, count)
                    task.wait(1)
                end

                if farmRunning then
                    local collectList, totalValue = getTokens()
                    if #collectList > 0 then
                        setStatus(string.format("Collecting: %d Tickets...", totalValue), Color3.fromRGB(100, 220, 255))
                        for idx, itemData in ipairs(collectList) do
                            if not farmRunning then break end
                            local part = itemData.Part
                            hrp = getHRP()
                            if hrp and part and part.Parent then
                                hrp.CFrame = CFrame.new(part.Position + Vector3.new(0, 1.5, 0))
                                waitLbl.Text = string.format("Collecting item: %d / %d", idx, #collectList)
                                sessionEarnedTokens = sessionEarnedTokens + (itemData.Value or 1)
                                -- Update telemetry cache so dashboard shows real-time ticket count
                                lastKnownTickets = lastKnownTickets + (itemData.Value or 1)
                                task.wait(0.8)
                            end
                        end

                        -- Force teleport back to safe position (retry up to 3 times)
                        task.wait(0.5) -- beri jeda setelah collect terakhir
                        for attempt = 1, 5 do
                            hrp = getHRP()
                            if hrp and safePos then
                                pcall(function() hrp.CFrame = safePos end)
                                task.wait(0.5)
                                hrp = getHRP()
                                if hrp and (hrp.Position - safePos.Position).Magnitude < 25 then
                                    break
                                end
                            else
                                task.wait(1) -- tunggu respawn kalau mati
                            end
                        end
                        setStatus("Collection Completed!", Color3.fromRGB(100, 255, 140))
                        waitLbl.Text = "Waiting for new items..."
                        task.wait(1)
                    end
                end
            else
                setStatus("Waiting for tickets to spawn...", Color3.fromRGB(255, 229, 190))
                waitLbl.Text = "Items spawned: 0 item(s)"
            end
            
            -- ALWAYS force teleport back to safe pos at end of every cycle
            hrp = getHRP()
            if hrp and safePos and (hrp.Position - safePos.Position).Magnitude > 15 then
                hrp.CFrame = safePos
            end
        end
        task.wait(0.5)
    end
end

