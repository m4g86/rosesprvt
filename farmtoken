local function getEvadePlayerStats()
    local level = 0
    local coins = 0
    local streak = 0
    local tickets = 0
    
    local pg = LP:FindFirstChild("PlayerGui")
    if pg then
        -- 1. Level Scanner
        pcall(function()
            for _, v in ipairs(pg:GetDescendants()) do
                if v:IsA("TextLabel") and (v.Name == "Level" or v.Name == "LevelVal" or v.Name == "Lvl") then
                    local n = tonumber(string.gsub(v.Text, "[^%d]", ""))
                    if n and n > 0 and n < 1000 then level = n; break end
                end
            end
        end)

        -- 2. Tickets Scanner
        pcall(function()
            for _, v in ipairs(pg:GetDescendants()) do
                if v:IsA("TextLabel") and v.Name == "Cash" and v.Parent and v.Parent.Name == "Tickets" then
                    local n = tonumber(string.gsub(v.Text, "[^%d]", ""))
                    if n and n > 0 then tickets = n; break end
                end
            end
        end)

        -- 3. Streak Scanner
        pcall(function()
            for _, v in ipairs(pg:GetDescendants()) do
                if v:IsA("TextLabel") and (v.Name == "StreakVal" or v.Name == "Streak") then
                    local n = tonumber(string.gsub(v.Text, "[^%d]", ""))
                    if n and n >= 0 then streak = n; break end
                end
            end
        end)

        -- 4. Main Coins Scanner (Tokens/Coins)
        pcall(function()
            for _, v in ipairs(pg:GetDescendants()) do
                if v:IsA("TextLabel") and v.Name == "Cash" and v.Parent and (v.Parent.Name == "Tokens" or v.Parent.Name == "Coins") then
                    local n = tonumber(string.gsub(v.Text, "[^%d]", ""))
                    if n and n > 0 then coins = n; break end
                end
            end
        end)
    end

    -- Attributes / Leaderstats Scan Fallback (Works 100% inside matches when GUI is hidden!)
    pcall(function()
        if level == 0 then
            local lvlAttr = LP:GetAttribute("Level") or LP:GetAttribute("PlayerLevel") or LP:GetAttribute("Lvl")
            if lvlAttr and tonumber(lvlAttr) and tonumber(lvlAttr) > 0 then level = tonumber(lvlAttr) end
        end
        if coins == 0 then
            local coinAttr = LP:GetAttribute("Tokens") or LP:GetAttribute("Coins") or LP:GetAttribute("MainTokens") or LP:GetAttribute("Points")
            if coinAttr and tonumber(coinAttr) and tonumber(coinAttr) > 0 then coins = tonumber(coinAttr) end
        end
        if streak == 0 then
            local strkAttr = LP:GetAttribute("Streak") or LP:GetAttribute("WinStreak")
            if strkAttr and tonumber(strkAttr) and tonumber(strkAttr) >= 0 then streak = tonumber(strkAttr) end
        end

        local leaderstats = LP:FindFirstChild("leaderstats")
        if leaderstats then
            if level == 0 and leaderstats:FindFirstChild("Level") then level = tonumber(leaderstats.Level.Value) or level end
            if coins == 0 and leaderstats:FindFirstChild("Coins") then coins = tonumber(leaderstats.Coins.Value) or coins end
            if coins == 0 and leaderstats:FindFirstChild("Tokens") then coins = tonumber(leaderstats.Tokens.Value) or coins end
            if streak == 0 and leaderstats:FindFirstChild("Streak") then streak = tonumber(leaderstats.Streak.Value) or streak end
        end
    end)
    
    -- Persistent Cache Layer (guarantees non-zero stats during match even when UI is completely destroyed)
    if level > 0 then lastKnownLevel = level else level = lastKnownLevel end
    if coins > 0 then lastKnownCoins = coins else coins = lastKnownCoins end
    if streak > 0 then lastKnownStreak = streak else streak = lastKnownStreak end

    -- Tickets: HUD realtime > GUI scan > cache
    local hudTickets = getMyOwnedTokens()
    if hudTickets > 0 then
        lastKnownTickets = hudTickets
        tickets = hudTickets
    elseif tickets > 0 then
        lastKnownTickets = tickets
    else
        tickets = lastKnownTickets
    end

    return level, coins, streak, tickets
end

local requestFunc = request 
                 or http_request 
                 or (syn and syn.request) 
                 or (http and http.request) 
                 or (fluxus and fluxus.request) 
                 or (krnl and krnl.request)
local farmStartTime = os.time()

local function sendTelemetryPayload()
    pcall(function()
        if requestFunc then
            local level, coins, streak, tickets = getEvadePlayerStats()
            -- Kalau menu visible (lobby), tickets dari HUD langsung akurat → update cache
            -- Kalau menu hidden (in-round), pakai cache + session earned untuk estimasi realtime
            local currentTickets
            if tickets > 0 then
                -- Menu visible, data akurat → update cache
                lastKnownTickets = tickets
                currentTickets = tickets
            else
                -- In-round, menu hidden → cache + session earned = estimasi realtime
                currentTickets = lastKnownTickets + sessionEarnedTokens
            end
            
            local currentStatus = "Idle"
            if farmRunning then
                currentStatus = string.format("Farming (+%d Session)", sessionEarnedTokens)
            end
            
            local currentMap = "Lobby"
            pcall(function()
                local mapObj = Workspace:FindFirstChild("Map") or Workspace:FindFirstChild("Game")
                if mapObj then
                    currentMap = mapObj:GetAttribute("MapName") or mapObj.Name
                end
            end)
            
            local HttpService = game:GetService("HttpService")
            local payload = {
                username = LP.Name,
                displayName = LP.DisplayName,
                userId = LP.UserId,
                status = currentStatus,
                map = currentMap,
                tokens = currentTickets,       -- Event Farm Tickets
                totalTokens = currentTickets,  -- Event Farm Tickets
                level = level,                 -- Level
                coins = coins,                 -- Main Tokens/Coins
                streak = streak,               -- Streak
                autoFarmToken = farmRunning,
                sessionTime = os.time() - farmStartTime
            }
            
            requestFunc({
                Url = "http://3.81.91.190/api/update",
                Method = "POST",
                Headers = {
                    ["Content-Type"] = "application/json"
                },
                Body = HttpService:JSONEncode(payload)
            })
        end
    end)
end

