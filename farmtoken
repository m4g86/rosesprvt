local function formatNumber(n)
    n = math.floor(tonumber(n) or 0)
    local formatted = tostring(n)
    while true do
        local k
        formatted, k = string.gsub(formatted, "^(-?%d+)(%d%d%d)", '%1,%2')
        if k == 0 then break end
    end
    return formatted
end

local initialWalletBalance = nil

local function updateSessionFromWallet(currentWallet)
    if currentWallet and currentWallet > 0 then
        if not initialWalletBalance then
            initialWalletBalance = currentWallet
        end
        local delta = currentWallet - initialWalletBalance
        if delta > 0 then
            sessionEarnedTokens = delta
        end
    end
end

