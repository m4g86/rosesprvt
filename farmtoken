    btn.AutoButtonColor = false
    btn.Active = true
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

    -- 3D High Contrast Bevel Vertical Gradient (Pops Out 3D!)
    local grad = Instance.new("UIGradient", btn)
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(78, 96, 122)), -- Bright Light Reflective Top
        ColorSequenceKeypoint.new(1, Color3.fromRGB(26, 34, 46))   -- Deep Shadow Bottom
    })
    grad.Rotation = 90

    -- Outer Dark Line Stroke
    local btnStroke = Instance.new("UIStroke", btn)
    btnStroke.Color = Color3.fromRGB(12, 16, 24)
    btnStroke.Thickness = 1.2
    btnStroke.LineJoinMode = Enum.LineJoinMode.Round
    btnStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    -- Inner Inset Highlight Line (Automatic Dead-Centered Alignment)
    local innerHighlight = Instance.new("Frame", btn)
    innerHighlight.Name = "InnerHighlight"
    innerHighlight.AnchorPoint = Vector2.new(0.5, 0.5)
    innerHighlight.Position = UDim2.new(0.5, 0, 0.5, 0)
    innerHighlight.Size = UDim2.new(1, -4, 1, -4)
    innerHighlight.BackgroundTransparency = 1
    innerHighlight.BorderSizePixel = 0
    Instance.new("UICorner", innerHighlight).CornerRadius = UDim.new(0, 4) -- 6 - 2 = 4

    local highlightStroke = Instance.new("UIStroke", innerHighlight)
    highlightStroke.Color = Color3.fromRGB(110, 140, 180)
    highlightStroke.Thickness = 1.0
    highlightStroke.Transparency = 0.35
    highlightStroke.LineJoinMode = Enum.LineJoinMode.Round
    highlightStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    -- Text Overlay (Dead-Centered Vertically & Horizontally)
    local lbl = Instance.new("TextLabel", btn)
    lbl.Size = UDim2.new(1, 0, 1, 0)
    lbl.Position = UDim2.new(0, 0, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = text
    lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 10
    lbl.TextYAlignment = Enum.TextYAlignment.Center
    lbl.TextXAlignment = Enum.TextXAlignment.Center
    lbl.ZIndex = 3

    local textStroke = Instance.new("UIStroke", lbl)
    textStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Contextual
    textStroke.Color = Color3.fromRGB(12, 15, 22)
    textStroke.Thickness = 1.2

    -- Smooth Micro Hover & Press Animations
    local tInfoHover = TweenInfo.new(0.16, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
    local tInfoPress = TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, tInfoHover, { Position = UDim2.new(0, posX, 0, -2) }):Play()
        TweenService:Create(highlightStroke, tInfoHover, { Transparency = 0.20 }):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, tInfoHover, { Position = UDim2.new(0, posX, 0, 0) }):Play()
        TweenService:Create(highlightStroke, tInfoHover, { Transparency = 0.45 }):Play()
    end)
    btn.MouseButton1Down:Connect(function()
        TweenService:Create(btn, tInfoPress, { Position = UDim2.new(0, posX, 0, 1) }):Play()
    end)
    btn.MouseButton1Up:Connect(function()
        TweenService:Create(btn, tInfoPress, { Position = UDim2.new(0, posX, 0, -2) }):Play()
    end)

    if callback then btn.MouseButton1Click:Connect(callback) end
    return btn
end

