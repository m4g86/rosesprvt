-- Invisible Drag-to-Resize Area (No Icon, Bottom-Right Corner Hitbox)
local UserInputService = game:GetService("UserInputService")
local resizeHandle = Instance.new("TextButton", main)
resizeHandle.Name = "ResizeHandle"
resizeHandle.Size = UDim2.new(0, 24, 0, 24)
resizeHandle.Position = UDim2.new(1, -24, 1, -24)
resizeHandle.BackgroundTransparency = 1
resizeHandle.Text = ""
resizeHandle.ZIndex = 10

local isResizing = false
local startMousePos = Vector2.zero
local startScale = 1

resizeHandle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        isResizing = true
        isUserResized = true
        startMousePos = Vector2.new(input.Position.X, input.Position.Y)
        startScale = uiScale.Scale
        
        local moveConn, releaseConn
        moveConn = UserInputService.InputChanged:Connect(function(moveInput)
            if isResizing and (moveInput.UserInputType == Enum.UserInputType.MouseMovement or moveInput.UserInputType == Enum.UserInputType.Touch) then
                local deltaX = moveInput.Position.X - startMousePos.X
                local rawScale = startScale + (deltaX / 320)
                -- Snap scale in clean 0.05 steps to eliminate subpixel text & bevel stroke jitter!
                local snappedScale = math.clamp(math.floor(rawScale * 20 + 0.5) / 20, 0.55, 2.0)
                if uiScale.Scale ~= snappedScale then
                    uiScale.Scale = snappedScale
                end
            end
        end)
        
        releaseConn = UserInputService.InputEnded:Connect(function(endInput)
            if endInput.UserInputType == Enum.UserInputType.MouseButton1 or endInput.UserInputType == Enum.UserInputType.Touch then
                isResizing = false
                if moveConn then moveConn:Disconnect() end
                if releaseConn then releaseConn:Disconnect() end
            end
        end)
    end
end)

